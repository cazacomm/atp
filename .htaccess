# ============================================================
#  ATP Tarbes — Apache config (o2switch)
# ============================================================

Options -Indexes
DirectoryIndex index.html

RewriteEngine On

# ---- 1. Forcer HTTPS ----
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# ---- 2. Forcer non-www (canonical = https://atptarbes.fr) ----
RewriteCond %{HTTP_HOST} ^www\.atptarbes\.fr$ [NC]
RewriteRule ^(.*)$ https://atptarbes.fr/$1 [R=301,L]

# ---- 3. /index.html -> / ----
RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

# ---- 4. Supprimer le slash final sur les fichiers .html ----
RewriteCond %{REQUEST_URI} ^/(.+)\.html/$ [NC]
RewriteRule ^(.+)\.html/$ /$1.html [R=301,L]

# ---- 5. Anciennes URLs -> nouvelles (redirections 301) ----
# Mentions légales
RedirectMatch 301 ^/mentions-legales/?$ /mentions.html
RedirectMatch 301 ^/mentions-legales/index\.html$ /mentions.html

# Politique de confidentialité (fusionnée dans les mentions légales)
RedirectMatch 301 ^/politiques?-de?-confidentialite/?$ /mentions.html
RedirectMatch 301 ^/politique-confidentialite\.html$ /mentions.html
RedirectMatch 301 ^/politique-de-confidentialite/?$ /mentions.html

# Vidéo portes ouvertes (ancienne URL indexée)
RedirectMatch 301 ^/video-portes-ouvertes/?$ /

# Anciens chemins de pages internes (avec slash)
RedirectMatch 301 ^/tarifs/?$ /tarifs.html
RedirectMatch 301 ^/planning/?$ /planning.html
RedirectMatch 301 ^/salle/?$ /salle.html
RedirectMatch 301 ^/avis/?$ /avis.html
RedirectMatch 301 ^/equipe/?$ /equipeatp.html
RedirectMatch 301 ^/equipeatp/?$ /equipeatp.html

# ---- 6. Page 404 personnalisée ----
ErrorDocument 404 /404.html

# ============================================================
#  Performance — compression & cache
# ============================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/x-javascript application/json application/xml application/rss+xml image/svg+xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault                              "access plus 1 month"
  ExpiresByType text/html                     "access plus 0 seconds"
  ExpiresByType text/xml                      "access plus 0 seconds"
  ExpiresByType application/xml               "access plus 0 seconds"
  ExpiresByType application/json              "access plus 0 seconds"
  ExpiresByType text/css                      "access plus 1 year"
  ExpiresByType application/javascript        "access plus 1 year"
  ExpiresByType image/jpeg                    "access plus 1 year"
  ExpiresByType image/png                     "access plus 1 year"
  ExpiresByType image/webp                    "access plus 1 year"
  ExpiresByType image/svg+xml                 "access plus 1 year"
  ExpiresByType video/mp4                     "access plus 1 year"
  ExpiresByType font/woff2                    "access plus 1 year"
</IfModule>

# ============================================================
#  Sécurité — headers
# ============================================================
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
</IfModule>
